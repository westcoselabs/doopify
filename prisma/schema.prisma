generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  ADMIN
  STAFF
  VIEWER
}

enum ProductStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum ProductSalesMode {
  STANDARD
  COMING_SOON
  PRESALE
}

enum ProductFulfillmentType {
  PHYSICAL
  DIGITAL
}

enum OrderStatus {
  OPEN
  CLOSED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  VOIDED
  FAILED
}

enum FulfillmentStatus {
  UNFULFILLED
  PARTIALLY_FULFILLED
  FULFILLED
  RESTOCKED
}

enum FulfillmentState {
  PENDING
  OPEN
  SUCCESS
  CANCELLED
  ERROR
  FAILURE
}

enum DiscountType {
  CODE
  AUTOMATIC
}

enum DiscountMethod {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
  BUY_X_GET_Y
}

enum ShippingRateMethod {
  FLAT
  SUBTOTAL_TIER
}

enum ShippingMode {
  MANUAL
  LIVE_RATES
  HYBRID
}

enum ShippingLiveProvider {
  EASYPOST
  SHIPPO
}

enum ShippingProviderUsage {
  LIVE_AND_LABELS
  LABELS_ONLY
  LIVE_RATES_ONLY
}

enum ShippingProviderSelection {
  NONE
  EASYPOST
  SHIPPO
}

enum ShippingFallbackBehavior {
  SHOW_FALLBACK
  HIDE_SHIPPING
  MANUAL_QUOTE
}

enum ShippingPackageType {
  BOX
  POLY_MAILER
  ENVELOPE
  CUSTOM
}

enum ShippingDimensionUnit {
  IN
  CM
}

enum ShippingWeightUnit {
  OZ
  LB
  G
  KG
}

enum ShippingManualRateType {
  FLAT
  FREE
  WEIGHT_BASED
  PRICE_BASED
}

enum TaxStrategy {
  NONE
  MANUAL
}

enum DiscountStatus {
  ACTIVE
  SCHEDULED
  EXPIRED
  DISABLED
}

enum OrderAddressType {
  SHIPPING
  BILLING
}

enum OrderEventActorType {
  SYSTEM
  STAFF
  CUSTOMER
}

enum ReturnStatus {
  REQUESTED
  APPROVED
  IN_TRANSIT
  RECEIVED
  CLOSED
  DECLINED
}

enum CheckoutSessionStatus {
  PENDING
  COMPLETED
  FAILED
  EXPIRED
}

enum WebhookDeliveryStatus {
  RECEIVED
  PROCESSED
  FAILED
  SIGNATURE_FAILED
  RETRY_PENDING
  RETRY_EXHAUSTED
}

enum RefundStatus {
  PENDING
  ISSUED
  FAILED
}

enum EmailDeliveryStatus {
  PENDING
  SENT
  FAILED
  BOUNCED
  COMPLAINED
  RETRYING
  RESEND_REQUESTED
}

enum JobStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  RETRYING
  EXHAUSTED
  CANCELLED
}

model Store {
  id                String   @id @default(cuid())
  name              String
  email             String?
  phone             String?
  domain            String?  @unique
  currency          String   @default("USD")
  timezone          String   @default("America/New_York")
  logoUrl           String?
  faviconUrl        String?
  emailLogoUrl      String?
  checkoutLogoUrl   String?
  primaryColor      String   @default("#000000")
  secondaryColor    String   @default("#ffffff")
  accentColor       String?
  textColor         String?
  headingFont       String?
  bodyFont          String?
  buttonRadius      String?  @default("md")
  buttonStyle       String?  @default("solid")
  buttonTextTransform String? @default("normal")
  emailHeaderColor  String?
  emailFooterText   String?
  supportEmail      String?
  instagramUrl      String?
  facebookUrl       String?
  tiktokUrl         String?
  youtubeUrl        String?
  address1          String?
  address2          String?
  city              String?
  province          String?
  postalCode        String?
  country           String?
  shippingThresholdCents Int?
  shippingDomesticRateCents Int   @default(999)
  shippingInternationalRateCents Int @default(1999)
  shippingMode      ShippingMode @default(MANUAL)
  shippingLiveProvider ShippingLiveProvider?
  shippingProviderUsage ShippingProviderUsage @default(LIVE_AND_LABELS)
  activeRateProvider ShippingProviderSelection @default(NONE)
  labelProvider      ShippingProviderSelection @default(NONE)
  fallbackBehavior   ShippingFallbackBehavior @default(SHOW_FALLBACK)
  shippingOriginName String?
  shippingOriginPhone String?
  shippingOriginAddress1 String?
  shippingOriginAddress2 String?
  shippingOriginCity String?
  shippingOriginProvince String?
  shippingOriginPostalCode String?
  shippingOriginCountry String?
  defaultPackageWeightOz Int?
  defaultPackageLengthIn Float?
  defaultPackageWidthIn Float?
  defaultPackageHeightIn Float?
  defaultLabelFormat String? @default("PDF")
  defaultLabelSize String? @default("4x6")
  shippingFallbackEnabled Boolean @default(true)
  manualFulfillmentInstructions String?
  manualTrackingBehavior String?
  localDeliveryEnabled Boolean @default(false)
  localDeliveryPriceCents Int?
  localDeliveryMinimumOrderCents Int?
  localDeliveryCoverage String?
  localDeliveryInstructions String?
  pickupEnabled Boolean @default(false)
  pickupLocation String?
  pickupInstructions String?
  pickupEstimate String?
  packingSlipUseLogo Boolean @default(true)
  packingSlipShowSku Boolean @default(true)
  packingSlipShowProductImages Boolean @default(false)
  packingSlipFooterNote String?
  domesticTaxRate   Float   @default(0.07)
  internationalTaxRate Float @default(0.0)
  taxEnabled        Boolean @default(false)
  taxStrategy       TaxStrategy @default(NONE)
  defaultTaxRateBps Int     @default(0)
  taxShipping       Boolean @default(false)
  pricesIncludeTax  Boolean @default(false)
  taxOriginCountry  String?
  taxOriginState    String?
  taxOriginPostalCode String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  shippingZones     ShippingZone[]
  shippingPackages  ShippingPackage[]
  shippingLocations ShippingLocation[]
  shippingManualRates ShippingManualRate[]
  shippingFallbackRates ShippingFallbackRate[]
  taxRules          TaxRule[]

  @@map("stores")
}

model ShippingZone {
  id          String         @id @default(cuid())
  storeId     String
  name        String
  countryCode String
  provinceCode String?
  isActive    Boolean        @default(true)
  priority    Int            @default(100)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  store       Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  rates       ShippingRate[]

  @@index([storeId, isActive, priority])
  @@index([countryCode, provinceCode])
  @@map("shipping_zones")
}

model ShippingRate {
  id             String             @id @default(cuid())
  shippingZoneId String
  name           String
  method         ShippingRateMethod @default(FLAT)
  amountCents         Int
  minSubtotalCents    Int?
  maxSubtotalCents    Int?
  isActive       Boolean            @default(true)
  priority       Int                @default(100)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  shippingZone   ShippingZone       @relation(fields: [shippingZoneId], references: [id], onDelete: Cascade)

  @@index([shippingZoneId, isActive, priority])
  @@map("shipping_rates")
}

model ShippingPackagePreset {
  id        String   @id @default(cuid())
  name      String
  weightOz  Int?
  lengthIn  Float
  widthIn   Float
  heightIn  Float
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("shipping_package_presets")
}

model ShippingPackage {
  id                 String                @id @default(cuid())
  storeId            String
  name               String
  type               ShippingPackageType   @default(BOX)
  length             Float
  width              Float
  height             Float
  dimensionUnit      ShippingDimensionUnit @default(IN)
  emptyPackageWeight Float
  weightUnit         ShippingWeightUnit    @default(OZ)
  isDefault          Boolean               @default(false)
  isActive           Boolean               @default(true)
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  store              Store                 @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, isActive])
  @@map("shipping_packages")
}

model ShippingLocation {
  id            String   @id @default(cuid())
  storeId       String
  name          String
  contactName   String?
  email         String?
  company       String?
  address1      String
  address2      String?
  city          String
  stateProvince String?
  postalCode    String
  country       String
  phone         String?
  isDefault     Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, isActive])
  @@map("shipping_locations")
}

model ShippingManualRate {
  id                    String                 @id @default(cuid())
  storeId               String
  name                  String
  regionCountry         String?
  regionStateProvince   String?
  rateType              ShippingManualRateType @default(FLAT)
  amountCents           Int
  minWeight             Float?
  maxWeight             Float?
  minSubtotalCents      Int?
  maxSubtotalCents      Int?
  freeOverAmountCents   Int?
  estimatedDeliveryText String?
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  store                 Store                  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, isActive])
  @@map("shipping_manual_rates")
}

model ShippingFallbackRate {
  id                    String   @id @default(cuid())
  storeId               String
  name                  String
  regionCountry         String?
  regionStateProvince   String?
  amountCents           Int
  estimatedDeliveryText String?
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  store                 Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, isActive])
  @@map("shipping_fallback_rates")
}

model TaxRule {
  id           String   @id @default(cuid())
  storeId      String
  name         String
  countryCode  String
  provinceCode String?
  rate         Float
  isActive     Boolean  @default(true)
  priority     Int      @default(100)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, isActive, priority])
  @@index([countryCode, provinceCode])
  @@map("tax_rules")
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  passwordHash   String
  firstName      String?
  lastName       String?
  role           UserRole        @default(STAFF)
  isActive       Boolean         @default(true)
  mfaTotpSecretEnc String?
  mfaTotpPendingSecretEnc String?
  mfaEnabledAt    DateTime?
  mfaRecoveryCodesHash String[] @default([])
  mfaGracePeriodEndsAt DateTime?
  lastLoginAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  sessions       Session[]
  mfaChallenges  MfaLoginChallenge[]
  passwordResets PasswordReset[]

  @@index([email])
  @@map("users")
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_resets")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("sessions")
}

model MfaLoginChallenge {
  id           String   @id @default(cuid())
  userId       String
  expiresAt    DateTime
  consumedAt   DateTime?
  attemptCount Int      @default(0)
  ip           String?
  userAgent    String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([expiresAt])
  @@map("mfa_login_challenges")
}

model UserInvite {
  id          String   @id @default(cuid())
  email       String
  role        UserRole @default(STAFF)
  tokenHash   String   @unique
  expiresAt   DateTime
  invitedById String?
  createdAt   DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
  @@map("user_invites")
}

model RateLimitWindow {
  key       String   @id
  count     Int
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
  @@map("rate_limit_windows")
}

model Product {
  id                    String                 @id @default(cuid())
  title                 String
  handle                String                 @unique
  status                ProductStatus          @default(DRAFT)
  publishedAt           DateTime?
  salesMode             ProductSalesMode       @default(STANDARD)
  presaleStartsAt       DateTime?
  presaleEndsAt         DateTime?
  availableForPurchaseAt DateTime?
  expectedDeliveryText  String?
  availabilityMessage   String?
  storefrontBadgeText   String?
  fulfillmentType       ProductFulfillmentType @default(PHYSICAL)
  description           String?                @db.Text
  vendor                String?
  productType           String?
  tags                  String[]
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  variants              ProductVariant[]
  options               ProductOption[]
  media                 ProductMedia[]
  collections           CollectionProduct[]
  orderItems            OrderItem[]

  @@index([handle])
  @@index([status])
  @@map("products")
}

model ProductVariant {
  id                            String            @id @default(cuid())
  productId                     String
  title                         String
  sku                           String?           @unique
  priceCents                    Int
  compareAtPriceCents           Int?
  inventory                     Int               @default(0)
  continueSellingWhenOutOfStock Boolean           @default(false)
  weight                        Float?
  weightUnit                    String?           @default("kg")
  position                      Int               @default(0)
  createdAt                     DateTime          @default(now())
  updatedAt                     DateTime          @updatedAt
  product                       Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  fulfillmentItems              FulfillmentItem[]
  orderItems                    OrderItem[]

  @@index([productId])
  @@index([sku])
  @@map("product_variants")
}

model ProductOption {
  id        String               @id @default(cuid())
  productId String
  name      String
  position  Int                  @default(0)
  product   Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  values    ProductOptionValue[]

  @@index([productId])
  @@map("product_options")
}

model ProductOptionValue {
  id       String        @id @default(cuid())
  optionId String
  value    String
  position Int           @default(0)
  option   ProductOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@index([optionId])
  @@map("product_option_values")
}

model MediaAsset {
  id           String         @id @default(cuid())
  filename     String
  altText      String?
  mimeType     String         @default("application/octet-stream")
  size         Int?
  width        Int?
  height       Int?
  data         Bytes?
  storageProvider String      @default("postgres")
  storageKey    String?
  storageBucket String?
  publicUrl     String?
  createdAt    DateTime       @default(now())
  productMedia ProductMedia[]

  @@index([storageProvider])
  @@index([storageKey])
  @@map("media_assets")
}

model ProductMedia {
  id         String     @id @default(cuid())
  productId  String
  assetId    String
  position   Int        @default(0)
  isFeatured Boolean    @default(false)
  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  asset      MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([productId, assetId])
  @@index([productId])
  @@map("product_media")
}

model Collection {
  id          String              @id @default(cuid())
  title       String
  handle      String              @unique
  description String?             @db.Text
  imageUrl    String?
  sortOrder   String              @default("MANUAL")
  isAutomated Boolean             @default(false)
  isPublished Boolean             @default(true)
  conditions  Json?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  products    CollectionProduct[]

  @@index([handle])
  @@map("collections")
}

model CollectionProduct {
  collectionId String
  productId    String
  position     Int        @default(0)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([collectionId, productId])
  @@map("collection_products")
}

model Customer {
  id               String            @id @default(cuid())
  email            String            @unique
  firstName        String?
  lastName         String?
  phone            String?
  passwordHash     String?
  acceptsMarketing Boolean           @default(false)
  tags             String[]
  note             String?
  totalSpentCents       Int               @default(0)
  orderCount       Int               @default(0)
  defaultAddressId String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  addresses        CustomerAddress[]
  checkoutSessions CheckoutSession[]
  orders           Order[]

  @@index([email])
  @@map("customers")
}

model CustomerAddress {
  id         String   @id @default(cuid())
  customerId String
  firstName  String?
  lastName   String?
  company    String?
  address1   String?
  address2   String?
  city       String?
  province   String?
  postalCode String?
  country    String?
  phone      String?
  isDefault  Boolean  @default(false)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_addresses")
}

model Order {
  id                   String                @id @default(cuid())
  orderNumber          Int                   @unique @default(autoincrement())
  customerId           String?
  email                String?
  status               OrderStatus           @default(OPEN)
  paymentStatus        PaymentStatus         @default(PENDING)
  fulfillmentStatus    FulfillmentStatus     @default(UNFULFILLED)
  subtotalCents             Int                   @default(0)
  taxAmountCents            Int                   @default(0)
  shippingAmountCents       Int                   @default(0)
  shippingMethodName        String?
  shippingRateType          String?
  shippingProvider          String?
  shippingProviderRateId    String?
  estimatedDeliveryText     String?
  discountAmountCents       Int                   @default(0)
  totalCents                Int                   @default(0)
  currency             String                @default("USD")
  channel              String                @default("online")
  note                 String?
  tags                 String[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  customer             Customer?             @relation(fields: [customerId], references: [id], onDelete: SetNull)
  items                OrderItem[]
  addresses            OrderAddress[]
  payments             Payment[]
  fulfillments         Fulfillment[]
  events               OrderEvent[]
  refunds              Refund[]
  returns              Return[]
  discountApplications DiscountApplication[]
  shippingLabels       ShippingLabel[]

  @@index([orderNumber])
  @@index([customerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id               String           @id @default(cuid())
  orderId          String
  productId        String?
  variantId        String?
  title            String
  variantTitle     String?
  sku              String?
  priceCents            Int
  quantity         Int
  totalDiscountCents    Int              @default(0)
  totalCents            Int
  order            Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product          Product?         @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant          ProductVariant?  @relation(fields: [variantId], references: [id], onDelete: SetNull)
  fulfillmentItems FulfillmentItem[]

  @@index([orderId])
  @@map("order_items")
}

model OrderAddress {
  id         String           @id @default(cuid())
  orderId    String
  type       OrderAddressType
  firstName  String?
  lastName   String?
  company    String?
  address1   String?
  address2   String?
  city       String?
  province   String?
  postalCode String?
  country    String?
  phone      String?
  order      Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_addresses")
}

model OrderEvent {
  id        String              @id @default(cuid())
  orderId   String
  type      String
  title     String
  detail    String?
  actorType OrderEventActorType @default(SYSTEM)
  actorId   String?
  createdAt DateTime            @default(now())
  order     Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_events")
}

model Payment {
  id                    String        @id @default(cuid())
  orderId               String
  provider              String        @default("stripe")
  amountCents                Int
  currency              String        @default("USD")
  status                PaymentStatus @default(PENDING)
  stripePaymentIntentId String?       @unique
  stripeChargeId        String?
  receiptUrl            String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  order                 Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  refunds               Refund[]

  @@index([orderId])
  @@index([stripePaymentIntentId])
  @@map("payments")
}

model CheckoutSession {
  id              String                @id @default(cuid())
  paymentIntentId String                @unique
  customerId      String?
  email           String?
  status          CheckoutSessionStatus @default(PENDING)
  currency        String                @default("USD")
  subtotalCents        Int                   @default(0)
  taxAmountCents       Int                   @default(0)
  shippingAmountCents  Int                   @default(0)
  discountAmountCents  Int                   @default(0)
  totalCents           Int                   @default(0)
  payload         Json
  failureReason   String?
  abandonedAt     DateTime?
  recoveryToken   String?               @unique
  recoveryEmailSentAt DateTime?
  recoveryEmailCount  Int               @default(0)
  recoveredAt     DateTime?
  completedAt     DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  customer        Customer?             @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([status, createdAt])
  @@index([status])
  @@index([createdAt])
  @@index([abandonedAt])
  @@index([recoveryToken])
  @@index([recoveryEmailSentAt])
  @@map("checkout_sessions")
}

model WebhookDelivery {
  id              String                @id @default(cuid())
  provider        String
  providerEventId String
  eventType       String
  status          WebhookDeliveryStatus @default(RECEIVED)
  attempts        Int                   @default(1)
  processedAt     DateTime?
  lastError       String?
  payloadHash     String
  rawPayload      String?               @db.Text
  nextRetryAt     DateTime?
  lastRetriedAt   DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@unique([provider, providerEventId])
  @@index([provider, eventType])
  @@index([status, createdAt])
  @@index([status, nextRetryAt])
  @@map("webhook_deliveries")
}

model Fulfillment {
  id             String           @id @default(cuid())
  orderId        String
  status         FulfillmentState @default(PENDING)
  locationName   String?
  carrier        String?
  service        String?
  trackingNumber String?
  trackingUrl    String?
  labelUrl       String?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  order          Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  items          FulfillmentItem[]
  shippingLabels ShippingLabel[]

  @@index([orderId])
  @@map("fulfillments")
}

model FulfillmentItem {
  id            String          @id @default(cuid())
  fulfillmentId String
  orderItemId   String
  variantId     String?
  quantity      Int
  fulfillment   Fulfillment     @relation(fields: [fulfillmentId], references: [id], onDelete: Cascade)
  orderItem     OrderItem       @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  variant       ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([fulfillmentId])
  @@map("fulfillment_items")
}

model ShippingLabel {
  id                 String   @id @default(cuid())
  fulfillmentId      String?
  orderId            String
  provider           String
  providerShipmentId String?
  providerRateId     String?
  providerLabelId    String?
  carrier            String?
  service            String?
  status             String   @default("PURCHASED")
  labelUrl           String?
  labelFormat        String?
  trackingNumber     String?
  trackingUrl        String?
  rateAmountCents    Int?
  labelAmountCents   Int?
  currency           String   @default("USD")
  rawResponse        Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  order              Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fulfillment        Fulfillment? @relation(fields: [fulfillmentId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([fulfillmentId])
  @@index([provider, providerLabelId])
  @@map("shipping_labels")
}

model Refund {
  id             String       @id @default(cuid())
  orderId        String
  paymentId      String?
  stripeRefundId String?      @unique
  status         RefundStatus @default(PENDING)
  amountCents         Int
  reason         String?
  note           String?
  restockItems   Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  order          Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  payment        Payment?     @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  items          RefundItem[]
  returnSource   Return?

  @@index([orderId])
  @@map("refunds")
}

model RefundItem {
  id          String  @id @default(cuid())
  refundId    String
  orderItemId String
  variantId   String?
  quantity    Int
  amountCents      Int
  refund      Refund  @relation(fields: [refundId], references: [id], onDelete: Cascade)

  @@index([refundId])
  @@map("refund_items")
}

model Return {
  id         String       @id @default(cuid())
  orderId    String
  refundId   String?      @unique
  status     ReturnStatus @default(REQUESTED)
  reason     String?
  note       String?
  receivedAt DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  order      Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  refund     Refund?      @relation(fields: [refundId], references: [id], onDelete: SetNull)
  items      ReturnItem[]

  @@index([orderId])
  @@map("returns")
}

model ReturnItem {
  id          String  @id @default(cuid())
  returnId    String
  orderItemId String
  variantId   String?
  quantity    Int
  reason      String?
  return      Return  @relation(fields: [returnId], references: [id], onDelete: Cascade)

  @@index([returnId])
  @@map("return_items")
}

model Discount {
  id                    String                @id @default(cuid())
  code                  String?               @unique
  title                 String
  type                  DiscountType          @default(CODE)
  method                DiscountMethod        @default(PERCENTAGE)
  value                 Int
  minimumOrderCents          Int?
  usageLimit            Int?
  usageCount            Int                   @default(0)
  status                DiscountStatus        @default(ACTIVE)
  startsAt              DateTime?
  endsAt                DateTime?
  combinesWithOrders    Boolean               @default(false)
  combinesWithProducts  Boolean               @default(false)
  combinesWithShipping  Boolean               @default(false)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  applications          DiscountApplication[]

  @@index([code])
  @@index([status])
  @@map("discounts")
}

model DiscountApplication {
  id         String   @id @default(cuid())
  orderId    String
  discountId String
  amountCents     Int
  createdAt  DateTime @default(now())
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  discount   Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)

  @@unique([orderId, discountId])
  @@map("discount_applications")
}

model EmailDelivery {
  id                String              @id @default(cuid())
  event             String
  template          String
  recipientEmail    String
  subject           String
  status            EmailDeliveryStatus @default(PENDING)
  provider          String              @default("resend")
  providerMessageId String?
  attempts          Int                 @default(0)
  lastError         String?
  nextRetryAt       DateTime?
  sentAt            DateTime?
  bouncedAt         DateTime?
  complainedAt      DateTime?
  orderId           String?
  customerId        String?
  refundId          String?
  returnId          String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([status, createdAt])
  @@index([recipientEmail])
  @@index([orderId])
  @@index([providerMessageId])
  @@map("email_deliveries")
}

model Job {
  id          String    @id @default(cuid())
  type        String
  payload     Json
  status      JobStatus @default(PENDING)
  attempts    Int       @default(0)
  maxAttempts Int       @default(5)
  runAt       DateTime  @default(now())
  lockedAt    DateTime?
  lockedBy    String?
  processedAt DateTime?
  lastError   String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, runAt])
  @@index([type, status])
  @@index([lockedAt])
  @@map("jobs")
}

model JobRunnerHeartbeat {
  runnerName       String   @id
  lastStartedAt    DateTime?
  lastSucceededAt  DateTime?
  lastFailedAt     DateTime?
  lastErrorSummary String?  @db.Text
  lastDurationMs   Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([updatedAt])
  @@map("job_runner_heartbeats")
}

model LaunchReadinessSnapshot {
  id         String   @id @default(cuid())
  scope      String   @unique @default("default")
  payload    Json
  checkedAt  DateTime
  runByUserId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([checkedAt])
  @@map("launch_readiness_snapshots")
}

model AnalyticsEvent {
  id         String   @id @default(cuid())
  event      String
  payload    Json
  occurredAt DateTime @default(now())
  orderId    String?
  refundId   String?
  returnId   String?
  deliveryId String?
  createdAt  DateTime @default(now())

  @@index([event, occurredAt])
  @@index([orderId])
  @@index([refundId])
  @@index([returnId])
  @@index([deliveryId])
  @@map("analytics_events")
}

model Integration {
  id            String             @id @default(cuid())
  name          String
  type          String             @default("CUSTOM")
  webhookUrl    String?
  webhookSecret String?
  status        IntegrationStatus  @default(ACTIVE)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  events        IntegrationEvent[]
  secrets       IntegrationSecret[]
  deliveries    OutboundWebhookDelivery[]

  @@map("integrations")
}

enum IntegrationStatus {
  ACTIVE
  INACTIVE
}

model IntegrationEvent {
  id            String      @id @default(cuid())
  integrationId String
  event         String
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, event])
  @@index([integrationId])
  @@map("integration_events")
}

model IntegrationSecret {
  id            String      @id @default(cuid())
  integrationId String
  key           String
  value         String      @db.Text
  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, key])
  @@map("integration_secrets")
}

model OutboundWebhookDelivery {
  id            String                @id @default(cuid())
  integrationId String
  event         String
  payload       String                @db.Text
  status        OutboundDeliveryStatus @default(PENDING)
  statusCode    Int?
  responseBody  String?               @db.Text
  attempts      Int                   @default(0)
  lastRetriedAt DateTime?
  nextRetryAt   DateTime?
  processedAt   DateTime?
  lastError     String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  integration   Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([integrationId, status])
  @@index([status, nextRetryAt])
  @@map("outbound_webhook_deliveries")
}

enum OutboundDeliveryStatus {
  PENDING
  SUCCESS
  FAILED
  RETRYING
  EXHAUSTED
}

model EmailTemplateSetting {
  id           String   @id @default(cuid())
  templateKey  String   @unique
  enabled      Boolean  @default(true)
  subject      String?
  preheader    String?
  headerTitle  String?
  bodyText     String?
  buttonLabel  String?
  footerText   String?
  replyToEmail String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("email_template_settings")
}
